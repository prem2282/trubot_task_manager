NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/task-manager?replicaSet=rs0
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
INVITE_TOKEN_EXPIRY_DAYS=7

# Email — local dev uses Mailpit (see docker-compose.yml)
EMAIL_PROVIDER=smtp
EMAIL_FROM=Task Manager <noreply@localhost>
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false

# Production: switch to Resend (https://resend.com)
# EMAIL_PROVIDER=resend
# EMAIL_FROM=Task Manager <onboarding@yourdomain.com>
# RESEND_API_KEY=re_xxxxxxxx

EMAIL_VERIFICATION_EXPIRY_HOURS=24
PASSWORD_RESET_EXPIRY_HOURS=1
